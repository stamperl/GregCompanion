{
  "name": "click-foundry",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:host": "vite --host 0.0.0.0 --port 5173",
    "build": "tsc -b && vite build",
    "check": "npm run lint && npm run test && npm run build",
    "deploy:test": "npm run release:home-dev",
    "deploy:release": "npm run release:full",
    "lint": "oxlint",
    "preview": "vite preview",
    "release:home-dev": "node scripts/release-flow.mjs home-dev",
    "release:remote-dev": "node scripts/release-flow.mjs remote-dev",
    "release:full": "node scripts/release-flow.mjs full",
    "test": "vitest run",
    "cap:sync": "npm run build && cap sync",
    "ios:add": "cap add ios",
    "ios:open": "cap open ios",
    "update:data": "tsx scripts/update-data.ts"
  },
  "dependencies": {
    "@capacitor/core": "^8.4.1",
    "@capacitor/ios": "^8.4.1",
    "@capacitor/preferences": "^8.0.1",
    "adm-zip": "^0.5.17",
    "lucide-react": "^1.21.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.4.1",
    "@types/adm-zip": "^0.5.8",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "oxlint": "^1.69.0",
    "tsx": "^4.22.4",
    "typescript": "~6.0.2",
    "vite": "^8.1.0",
    "vitest": "^4.1.9"
  }
}
